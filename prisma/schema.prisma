generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String              @id
  email             String
  name              String?
  relayKeyHash      String?
  createdAt         DateTime            @default(now())
  threads           Thread[]
  lastDashboardUpdates DashboardLayout[] @relation("DashboardLastUpdate")
  feedbacks         MessageFeedback[]
  memberships       ProjectMember[]
  connectorSessions ConnectorSession[]
  joinRequests      ProjectJoinRequest[]
}

model Thread {
  id                String    @id @default(cuid())
  userId            String
  langGraphThreadId String
  title             String    @default("새 대화")
  projectName       String    @default("default") @map("project")
  projectId         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project           Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages          Message[]

  @@index([userId])
  @@index([projectId])
}

model Message {
  id        String            @id @default(cuid())
  threadId  String
  role      String
  content   String
  createdAt DateTime          @default(now())
  thread    Thread            @relation(fields: [threadId], references: [id], onDelete: Cascade)
  feedback  MessageFeedback[]

  @@index([threadId])
  @@index([threadId, createdAt])
}

model MessageFeedback {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

model DashboardLayout {
  id            String   @id @default(cuid())
  projectId     String   @unique
  layout        String
  lastUpdatedBy String?
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  updatedByUser User?    @relation("DashboardLastUpdate", fields: [lastUpdatedBy], references: [id], onDelete: SetNull)
}

model EvalPrompt {
  id         String   @id @default(cuid())
  name       String   // "hallucination", "citation", "tool_calling", or custom
  projectId  String?  // null = global (built-in), set = project-specific custom eval
  evalType   String   @default("llm_prompt") // "llm_prompt" | "code_rule" | "builtin"
  outputMode String   @default("score")      // "score" | "binary"
  template   String   @default("")           // prompt text for llm_prompt, empty for code_rule
  ruleConfig  String   @default("{}")         // JSON rule config for code_rule type
  badgeLabel   String   @default("")           // short name for annotation badge (e.g. "HAL", "CIT")
  description  String   @default("")           // human-readable description
  isCustom     Boolean  @default(false)
  model      String   @default("gpt-4o-mini")
  updatedAt  DateTime @updatedAt
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([name, projectId])
}

model ProjectEvalConfig {
  id         String  @id @default(cuid())
  projectId  String?
  evalName   String  // annotation name (e.g. "hallucination")
  enabled    Boolean @default(true)
  template   String? // project-specific prompt override (null = use global default)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, evalName])
}

model AgentConfig {
  id          String   @id @default(cuid())
  projectName String   @unique @map("project") // Phoenix project name
  alias       String?                   // Display name in dashboard (null = use project name)
  templateId  String?                   // AgentTemplate reference (null = custom)
  agentType   String   @default("langgraph")
  endpoint    String   @default("http://localhost:2024")
  assistantId String   @default("agent")
  projectId   String?
  updatedAt   DateTime @updatedAt
  template    AgentTemplate? @relation(fields: [templateId], references: [id])
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model AgentTemplate {
  id          String        @id @default(cuid())
  name        String
  userId      String?
  description String        @default("")
  agentType   String        @default("langgraph")
  endpoint    String        @default("http://localhost:2024")
  assistantId String        @default("agent")
  evalPrompts String        @default("{}") // JSON: {"hallucination": "...", "citation": "..."}
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  configs     AgentConfig[]

  @@unique([userId, name])
}

model AppSettings {
  id     String  @id @default(cuid())
  key    String
  value  String
  userId String?

  @@unique([key, userId])
}

model LlmProvider {
  id        String   @id @default(cuid())
  provider  String
  userId    String?
  projectId String?            // null = global (user-level), set = project-specific
  apiKey    String             // encrypted
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, provider])
  @@index([userId])
}

model Dataset {
  id            String       @id @default(cuid())
  name          String
  fileName      String       @default("")
  headers       String       @default("[]")
  queryCol      String       @default("")
  contextCol    String       @default("")
  evalNames     String       @default("[]")
  evalOverrides String       @default("{}")
  rowCount      Int          @default(0)
  projectId     String?
  datasetRows   DatasetRow[]
  runs          DatasetRun[]
  project       Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([projectId])
}

model DatasetRow {
  id        String  @id @default(cuid())
  datasetId String
  rowIndex  Int
  data      String  @default("{}")
  dataset   Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId, rowIndex])
}

model DatasetRun {
  id          String          @id @default(cuid())
  datasetId   String
  dataset     Dataset         @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  agentSource String          @default("")
  evalNames   String          @default("[]")
  status      String          @default("running")
  results     DatasetRunResult[]
  createdAt   DateTime        @default(now())
}

model DatasetRunResult {
  id        String     @id @default(cuid())
  runId     String
  rowIdx    Int
  response  String     @default("")
  query     String     @default("")
  evals     String     @default("{}") // JSON: Record<string, {label, score, explanation}>
  capture   String     @default("{}") // JSON: AgentRunCapture (toolCalls, thinking, iterations)
  run       DatasetRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, rowIdx])
}

model Project {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  phoenixProject    String              @default("")   // Phoenix 프로젝트명 (trace 조회용)
  traceKeyHash      String              @default("")
  traceKeyEncrypted String              @default("")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  members           ProjectMember[]
  agentConfigs      AgentConfig[]
  datasets          Dataset[]
  evalConfigs       ProjectEvalConfig[]
  evalPrompts       EvalPrompt[]
  dashboardLayouts  DashboardLayout[]
  threads           Thread[]
  connectorSessions ConnectorSession[]
  llmProviders      LlmProvider[]
  inviteCodes       ProjectInviteCode[]
  joinRequests      ProjectJoinRequest[]
  prompts           ProjectPrompt[]
  piiGuardRuns      PiiGuardRun[]
  rmfAssessment     RmfAssessment?
  rmfReportVersions RmfReportVersion[]
}

// 금융 AI RMF — 프로젝트별 현재 평가 설정/초안 (1건, upsert)
model RmfAssessment {
  id         String    @id @default(cuid())
  projectId  String    @unique
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  highImpact Boolean   @default(false)
  periodFrom DateTime?
  periodTo   DateTime?
  governance Json      @default("{}") // { key: { status, note } }
  controls   Json      @default("{}")
  riskItems  Json      @default("{}") // { itemKey: { mitigation, note, inherentOverride? } }
  assessor   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// 금융 AI RMF — 생성 시 저장되는 보고서 버전 스냅샷 (immutable, 다시보기)
model RmfReportVersion {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version    Int                      // 프로젝트 내 순번
  label      String?                  // 사용자 메모
  periodFrom DateTime?
  periodTo   DateTime?
  highImpact Boolean   @default(false)
  grade      String                   // 저/중/고/초고
  total      Int
  snapshot   Json                     // 계산된 보고서 전체(항목·소계·findings·거버넌스·통제)
  assessor   String?
  createdAt  DateTime  @default(now())

  @@unique([projectId, version])
  @@index([projectId, createdAt])
}

model PiiGuardRun {
  id             String   @id @default(cuid())
  projectId      String
  externalId     String   @default("")    // original benchmark id (e.g. "P001")
  category       String   @default("")    // clean | direct | obfuscated | cross_session | prompt_injection
  input          String
  expectedMasked String   @default("")
  actualMasked   String   @default("")
  detections     String   @default("{}")  // JSON: { stage1, stage2, combined }
  outcome        String                   // TP | TN | FP | FN | PARTIAL
  latencyMs      Int      @default(0)
  outputGuard    String?                  // JSON or null
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

// Project ↔ Phoenix prompt scoping. Phoenix's prompt registry is global by name,
// so we maintain this mapping in our own DB and filter all reads through it.
// Going forward every Phoenix prompt visible in the UI must have a row here.
model ProjectPrompt {
  id          String   @id @default(cuid())
  projectId   String
  phoenixName String
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, phoenixName])
  @@unique([phoenixName])
  @@index([projectId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("editor")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model ConnectorSession {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  agentType   String   @default("langgraph")
  assistantId String   @default("agent")
  status      String   @default("online")
  connectedAt DateTime @default(now())
  lastPingAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId, status])
}

model ProjectInviteCode {
  id           String    @id @default(cuid())
  projectId    String
  code         String    @unique
  role         String    @default("editor")
  maxUses      Int       @default(0)
  useCount     Int       @default(0)
  expiresAt    DateTime?
  createdBy    String
  createdAt    DateTime  @default(now())
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  joinRequests ProjectJoinRequest[]

  @@index([projectId])
}

model ProjectJoinRequest {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  codeId    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  code      ProjectInviteCode @relation(fields: [codeId], references: [id])

  @@unique([projectId, userId])
  @@index([projectId, status])
}
